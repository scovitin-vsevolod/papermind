# Anthropic Claude API key — get one at https://console.anthropic.com/
ANTHROPIC_API_KEY=

# OpenAI API key — used by the GPT-4 side of side-by-side comparison.
# Optional; if blank, requests with provider=openai will fail at call time.
OPENAI_API_KEY=

# Claude model used by the /ask endpoint.
#   claude-sonnet-4-6  — default ($3/$15)        — recommended for MVP
#   claude-opus-4-7    — most capable ($5/$25)   — switch when you want max quality
#   claude-haiku-4-5   — fastest/cheapest ($1/$5)
# See docs/models.md for details.
CLAUDE_MODEL=claude-sonnet-4-6

# OpenAI model used for the GPT-4 side of side-by-side comparison.
OPENAI_MODEL=gpt-4o

# Qdrant (vector DB)
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=papermind

# Neo4j (knowledge graph). Locally — match docker-compose.yml's NEO4J_AUTH.
# On production with Neo4j Aura: paste the contents of the credentials
# file Aura gives you on instance creation (or "Recover credentials").
# Note the variable name: NEO4J_USERNAME — that's what Aura writes, and
# our config reads exactly that. On Aura Free, the username equals the
# DB ID (e.g. `1ba5b58e`), NOT the string `neo4j`.
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=papermind-dev

# Session JWT secret. MUST be replaced before production deploy:
#   python3 -c "import secrets; print(secrets.token_urlsafe(64))"
# Rotating this invalidates all existing sessions (forces re-login).
JWT_SECRET=dev-only-change-me-in-production
JWT_SESSION_DAYS=30

# Metadata DB
DATABASE_URL=sqlite:///./papermind.db

# Embedding backend. "sentence-transformers" (local, free, 384 dim) or
# "voyage" (API, paid, 1024 dim). The Qdrant collection name carries the
# backend suffix so both can coexist (papermind_minilm, papermind_voyage).
EMBEDDING_PROVIDER=sentence-transformers

# Local sentence-transformers model (downloaded on first run)
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Voyage AI key — only required when EMBEDDING_PROVIDER=voyage or when
# running the retrieval experiment.
VOYAGE_API_KEY=
VOYAGE_MODEL=voyage-3
