# Anthropic Claude API key — get one at https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Claude model used by the /ask endpoint.
#   claude-sonnet-4-6  — default ($3/$15)        — recommended for MVP
#   claude-opus-4-7    — most capable ($5/$25)   — switch when you want max quality
#   claude-haiku-4-5   — fastest/cheapest ($1/$5)
# See docs/models.md for details.
CLAUDE_MODEL=claude-sonnet-4-6

# Qdrant (vector DB)
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=papermind

# Metadata DB
DATABASE_URL=sqlite:///./papermind.db

# Local sentence-transformers model (downloaded on first run)
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
